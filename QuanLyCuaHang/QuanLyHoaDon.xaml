<UserControl x:Class="QuanLyCuaHang.QuanLyHoaDon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="ORDER MANAGEMENT" 
                   FontSize="28" 
                   FontWeight="Bold" 
                   Foreground="#2C3E50" 
                   Margin="0,0,0,20"/>

        <!-- Search Bar -->
        <Border Grid.Row="1" 
                Background="White" 
                CornerRadius="8" 
                Padding="15" 
                Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
            </Border.Effect>
            
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Search:" 
                           VerticalAlignment="Center" 
                           FontSize="14" 
                           Margin="0,0,10,0"/>
                <TextBox x:Name="txtSearch" 
                         Width="300" 
                         Height="35" 
                         Padding="10" 
                         FontSize="14"
                         TextChanged="txtSearch_TextChanged"/>
                
                <Button x:Name="btnRefresh" 
                        Content="Refresh" 
                        Width="100" 
                        Height="35" 
                        Margin="10,0,0,0" 
                        Background="#3498DB" 
                        Foreground="White" 
                        BorderThickness="0"
                        Click="btnRefresh_Click"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" 
                Background="White" 
                CornerRadius="8" 
                Padding="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
            </Border.Effect>

            <DataGrid x:Name="dgOrders" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      SelectionMode="Single"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      RowHeight="40"
                      FontSize="13"
                      SelectionChanged="dgOrders_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Order ID" Binding="{Binding Id}" Width="80"/>
                    <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="150"/>
                    <DataGridTextColumn Header="Employee" Binding="{Binding EmployeeName}" Width="150"/>
                    <DataGridTextColumn Header="Total Amount" Binding="{Binding TotalAmount, StringFormat=${0:N2}}" Width="120"/>
                    <DataGridTextColumn Header="Order Date" Binding="{Binding OrderDate, StringFormat=MM/dd/yyyy HH:mm}" Width="150"/>
                    
                    <DataGridTemplateColumn Header="Actions" Width="250">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="View Details" 
                                            Width="100" 
                                            Height="30" 
                                            Margin="5,0" 
                                            Background="#16A085" 
                                            Foreground="White" 
                                            BorderThickness="0"
                                            Tag="{Binding Id}"
                                            Click="btnViewDetails_Click"/>
                                    
                                    <Button Content="Delete" 
                                            Width="80" 
                                            Height="30" 
                                            Margin="5,0" 
                                            Background="#E74C3C" 
                                            Foreground="White" 
                                            BorderThickness="0"
                                            Tag="{Binding Id}"
                                            Click="btnDelete_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Summary -->
        <Border Grid.Row="3" 
                Background="White" 
                CornerRadius="8" 
                Padding="15" 
                Margin="0,15,0,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Total Orders: " 
                           FontSize="16" 
                           FontWeight="SemiBold" 
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="txtTotalOrders" 
                           Text="0" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="#3498DB" 
                           Margin="5,0,30,0" 
                           VerticalAlignment="Center"/>
                
                <TextBlock Text="Total Revenue: $" 
                           FontSize="16" 
                           FontWeight="SemiBold" 
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="txtTotalRevenue" 
                           Text="0.00" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="#27AE60" 
                           Margin="5,0,0,0" 
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
