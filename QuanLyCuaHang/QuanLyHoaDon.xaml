<Window x:Class="QuanLyCuaHang.QuanLyHoaDon"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyCuaHang"
        mc:Ignorable="d"
        Title="Quản Lý Hóa Đơn" Height="650" Width="1100"
Background="#F5F6F8" FontFamily="Segoe UI">
    <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="1" Color="#DEDEDE"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="TRA CỨU HÓA ĐƠN" FontWeight="Bold" FontSize="22" Foreground="#2D3436" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <WrapPanel VerticalAlignment="Center">
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Từ ngày" Margin="0,0,0,5" Foreground="#636E72"/>
                            <DatePicker Name="dpFromDate" Width="350" Height="35" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Đến ngày" Margin="0,0,0,5" Foreground="#636E72"/>
                            <DatePicker Name="dpToDate" Width="350" Height="35" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Mã hóa đơn" Margin="0,0,0,5" Foreground="#636E72"/>
                            <TextBox Name="txtInvoiceId" Width="240" Height="35" VerticalContentAlignment="Center" Padding="5,0"/>
                        </StackPanel>


                    </WrapPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button Content="Tìm kiếm" Width="120" Height="45"
     Foreground="Black" FontWeight="SemiBold" Cursor="Hand" Click="btnSearch_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button Content="Tạo mới" Width="120" Height="45" Margin="12,0,0,0"
     Foreground="Black" FontWeight="SemiBold" Cursor="Hand" Click="btnAdd_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="1" Color="#DEDEDE"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid Name="dt_hoadon" Grid.Row="0" AutoGenerateColumns="False" 
                      CanUserAddRows="False" Background="White" BorderThickness="0"
                      RowHeight="40" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F2F6">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="STT" Binding="{Binding Stt}" Width="50"/>
                            <DataGridTextColumn Header="Mã Hóa Đơn" Binding="{Binding MaHoaDon}" Width="150"/>
                            <DataGridTextColumn Header="Ngày Lập" Binding="{Binding NgayLap, StringFormat=dd/MM/yyyy HH:mm, TargetNullValue=''}" Width="180"/>
                            <DataGridTextColumn Header="Khách Hàng" Binding="{Binding KhachHang}" Width="*"/>
                            <DataGridTextColumn Header="Tổng Tiền" Binding="{Binding TongTien, StringFormat={}{0:N0} VNĐ}" Width="150"/>
                            <DataGridTemplateColumn Header="Thao tác" Width="220">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Cập nhật" Margin="5,0" Padding="10,2" Background="White" Foreground="Black" BorderThickness="0"
                                                    CommandParameter="{Binding Id}" Click="btnUpdate_Click"/>
                                            <Button Content="Xóa" Padding="10,2" Background="White" Foreground="Black" BorderThickness="0"
                                                    CommandParameter="{Binding Id}" Click="btnDelete_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Margin="0,20,0,0" Padding="15" Background="#DFE6E9" CornerRadius="8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Tổng doanh thu:" VerticalAlignment="Center" FontSize="16" Foreground="#2D3436"/>
                    <TextBlock Name="lblTotalRevenue" Text="150,000 VNĐ" FontWeight="Bold" FontSize="20" Margin="15,0,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
</Window>
