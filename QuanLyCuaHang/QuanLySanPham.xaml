<Window x:Class="QuanLyCuaHang.QuanLySanPham"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyCuaHang"
        mc:Ignorable="d"
        Title="QuanLySanPham" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="15">
            <TextBlock Text="QUẢN LÍ SẢN PHẨM " FontWeight="Bold" FontSize="16" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <Label Content="Tên sản phẩm:"/>
            <TextBox Padding="5" Margin="0,0,0,10"/>

            <Label Content="Loại sản phẩm:"/>
            <ComboBox  Padding="5" Margin="0,0,0,10">
                <ComboBoxItem Content="Điện tử"/>
                <ComboBoxItem Content="Gia dụng"/>
                <ComboBoxItem Content="Thời trang"/>
            </ComboBox>

            <Label Content="Giá:"/>
            <TextBox x:Name="txtGia" Padding="5" Margin="0,0,0,10"/>

            <Label Content="Số lượng:"/>
            <TextBox Padding="5" Margin="0,0,0,20"/>

            <UniformGrid Columns="3">
                <Button Content="Thêm" Margin="0,0,5,0" Padding="5"/>
                <Button Content ="Sửa" Margin="2.5,0,2.5,0" Padding="5"/>
                <Button Content="Xóa" Margin="5,0,0,0" Padding="5"/>
            </UniformGrid>
        </StackPanel>

        <DockPanel Grid.Column="1" Margin="15">

            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Right">
                <TextBlock Text="Tìm kiếm:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox  Width="200" Padding="5"/>
            </StackPanel>

            <DataGrid x:Name="dgDanhSach" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tên SP" Binding="{Binding TenSP}" Width="*"/>
                    <DataGridTextColumn Header="Loại" Binding="{Binding LoaiSP}" Width="100"/>
                    <DataGridTextColumn Header="Giá" Binding="{Binding Gia}" Width="100"/>
                    <DataGridTextColumn Header="Số lượng" Binding="{Binding SoLuong}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>

        </DockPanel>

    </Grid>
</Window>
