<UserControl x:Class="QuanLyCuaHang.QuanLySanPham"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="PRODUCT MANAGEMENT" 
                   FontSize="28" 
                   FontWeight="Bold" 
                   Foreground="#2C3E50" 
                   Margin="0,0,0,20"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" 
                Background="White" 
                CornerRadius="8" 
                Padding="15" 
                Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnAdd" 
                        Content="+ Add Product" 
                        Width="130" 
                        Height="35" 
                        Background="#27AE60" 
                        Foreground="White" 
                        BorderThickness="0"
                        Click="btnAdd_Click"/>
                
                <TextBox x:Name="txtSearch" 
                         Width="300" 
                         Height="35" 
                         Padding="10" 
                         Margin="15,0,0,0"
                         FontSize="14"
                         TextChanged="txtSearch_TextChanged"/>
                
                <Button x:Name="btnRefresh" 
                        Content="Refresh" 
                        Width="100" 
                        Height="35" 
                        Margin="10,0,0,0" 
                        Background="#3498DB" 
                        Foreground="White" 
                        BorderThickness="0"
                        Click="btnRefresh_Click"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" 
                Background="White" 
                CornerRadius="8" 
                Padding="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
            </Border.Effect>

            <DataGrid x:Name="dgProducts" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      SelectionMode="Single"
                      CanUserAddRows="False"
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      RowHeight="40"
                      FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="Product Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat=${0:N2}}" Width="100"/>
                    <DataGridTextColumn Header="Stock" Binding="{Binding Quantity}" Width="80"/>
                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="80"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="200"/>
                    
                    <DataGridTemplateColumn Header="Actions" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="Edit" 
                                            Width="70" 
                                            Height="30" 
                                            Margin="5,0" 
                                            Background="#F39C12" 
                                            Foreground="White" 
                                            BorderThickness="0"
                                            Tag="{Binding}"
                                            Click="btnEdit_Click"/>
                                    
                                    <Button Content="Delete" 
                                            Width="70" 
                                            Height="30" 
                                            Margin="5,0" 
                                            Background="#E74C3C" 
                                            Foreground="White" 
                                            BorderThickness="0"
                                            Tag="{Binding Id}"
                                            Click="btnDelete_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
