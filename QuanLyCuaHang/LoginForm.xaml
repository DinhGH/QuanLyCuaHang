<Window x:Class="QuanLyCuaHang.LoginForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyCuaHang"
        mc:Ignorable="d"
        Title="LoginForm" Height="450" Width="800">
    <Grid>
        <Border Width="420" Padding="30" Background="White" CornerRadius="15" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.2"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="ĐĂNG NHẬP" FontSize="30" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <TextBlock Grid.Row="1" Text="Tên đăng nhập" FontSize="14" Foreground="#34495E" Margin="0,0,0,5"/>
i
                <Border Grid.Row="2" CornerRadius="8" BorderBrush="#D0D3D4" BorderThickness="1" Margin="0,0,0,10">
                    <TextBox x:Name="txtUsername" Height="40" FontSize="14" Padding="10" BorderThickness="0" Background="Transparent"/>
                </Border>

                <TextBlock Grid.Row="3" Text="Mật khẩu" FontSize="14" Foreground="#34495E" Margin="0,5,0,5"/>

                <Border Grid.Row="4" CornerRadius="8" BorderBrush="#D0D3D4" BorderThickness="1">
                    <PasswordBox x:Name="txtPassword" Height="40" FontSize="14" Padding="10" BorderThickness="0" Background="Transparent" PasswordChanged="TxtPassword_PasswordChanged"/>
                </Border>

                <TextBlock x:Name="lblError" Grid.Row="5" Foreground="Red" FontSize="12" Margin="0,10,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>

                <Button x:Name="btnLogin" Grid.Row="6" Content="ĐĂNG NHẬP" Height="45" Margin="0,25,0,10" FontSize="16" FontWeight="Bold" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnLogin_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2E86C1"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="btnRegister" Grid.Row="7" Content="Chưa có tài khoản? Đăng ký ngay" Background="Transparent" Foreground="#3498DB" BorderThickness="0" FontSize="13" Cursor="Hand" Click="BtnRegister_Click" HorizontalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
