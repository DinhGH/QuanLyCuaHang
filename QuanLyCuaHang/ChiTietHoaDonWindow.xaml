<Window x:Class="QuanLyCuaHang.ChiTietHoaDonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Order Details"
        Height="600"
        Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="ORDER DETAILS" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   Foreground="#2C3E50" 
                   Margin="0,0,0,20"/>

        <!-- Order Info -->
        <Border Grid.Row="1" 
                Background="White" 
                CornerRadius="8" 
                Padding="20" 
                Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Order Information" 
                               FontSize="16" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Order ID: " FontWeight="SemiBold" Width="100"/>
                        <TextBlock x:Name="txtOrderId" Text=""/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Customer: " FontWeight="SemiBold" Width="100"/>
                        <TextBlock x:Name="txtCustomer" Text=""/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Employee: " FontWeight="SemiBold" Width="100"/>
                        <TextBlock x:Name="txtEmployee" Text=""/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Date and Payment" 
                               FontSize="16" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Date: " FontWeight="SemiBold" Width="100"/>
                        <TextBlock x:Name="txtDate" Text=""/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Total: " FontWeight="SemiBold" Width="100"/>
                        <TextBlock x:Name="txtTotal" Text="" Foreground="#27AE60" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Items DataGrid -->
        <Border Grid.Row="2" 
                Background="White" 
                CornerRadius="8" 
                Padding="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
            </Border.Effect>

            <DataGrid x:Name="dgItems" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      RowHeight="35"
                      FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding RowNumber}" Width="50"/>
                    <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*"/>
                    <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100"/>
                    <DataGridTextColumn Header="Unit Price" Binding="{Binding Price, StringFormat=${0:N2}}" Width="120"/>
                    <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=${0:N2}}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Close Button -->
        <Button Grid.Row="3" 
                Content="Close" 
                Width="100" 
                Height="40" 
                Margin="0,15,0,0" 
                Background="#95A5A6" 
                Foreground="White" 
                BorderThickness="0" 
                FontSize="14" 
                FontWeight="SemiBold"
                HorizontalAlignment="Right"
                Click="btnClose_Click"/>
    </Grid>
</Window>