<Window x:Class="QuanLyCuaHang.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Product Management"
        Height="650"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" 
                Background="#2C3E50" 
                CornerRadius="8" 
                Padding="15" 
                Margin="0,0,0,15">
            <TextBlock x:Name="txtTitle" 
                       Text="ADD NEW PRODUCT" 
                       FontSize="22"
                       FontWeight="Bold" 
                       Foreground="White" 
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Form -->
        <Border Grid.Row="1" 
                Background="White" 
                CornerRadius="8" 
                Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column: Basic Info -->
                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <!-- Product ID (Display only in edit mode) -->
                    <StackPanel x:Name="pnlProductId" Visibility="Collapsed">
                        <TextBlock Text="Product ID" 
                                   FontSize="13" 
                                   FontWeight="SemiBold" 
                                   Foreground="#2C3E50" 
                                   Margin="0,0,0,5"/>
                        <Border Background="#ECF0F1" 
                                CornerRadius="5" 
                                Padding="5" 
                                Margin="0,0,0,12">
                            <TextBlock x:Name="txtProductId" 
                                       Text="N/A" 
                                       FontSize="13" 
                                       Foreground="#7F8C8D"/>
                        </Border>
                    </StackPanel>

                    <!-- Product Name -->
                    <TextBlock FontSize="13" 
                               FontWeight="SemiBold" 
                               Foreground="#2C3E50" 
                               Margin="0,0,0,5">
                        <Run Text="Product Name"/>
                        <Run Text=" *" Foreground="#E74C3C"/>
                    </TextBlock>
                    <TextBox x:Name="txtName" 
                             Height="35" 
                             Padding="5" 
                             FontSize="13" 
                             Margin="0,0,0,12"
                             BorderBrush="#BDC3C7"/>

                    <!-- Price -->
                    <TextBlock FontSize="13" 
                               FontWeight="SemiBold" 
                               Foreground="#2C3E50" 
                               Margin="0,0,0,5">
                        <Run Text="Price ($)"/>
                        <Run Text=" *" Foreground="#E74C3C"/>
                    </TextBlock>
                    <TextBox x:Name="txtPrice" 
                             Height="35" 
                             Padding="5" 
                             FontSize="13" 
                             Margin="0,0,0,12"
                             BorderBrush="#BDC3C7"/>

                    <!-- Quantity -->
                    <TextBlock FontSize="13" 
                               FontWeight="SemiBold" 
                               Foreground="#2C3E50" 
                               Margin="0,0,0,5">
                        <Run Text="Stock Quantity"/>
                        <Run Text=" *" Foreground="#E74C3C"/>
                    </TextBlock>
                    <TextBox x:Name="txtQuantity" 
                             Height="35" 
                             Padding="5" 
                             FontSize="13" 
                             Margin="0,0,0,12"
                             BorderBrush="#BDC3C7"/>

                    <!-- Unit -->
                    <TextBlock Text="Unit of Measure" 
                               FontSize="13" 
                               FontWeight="SemiBold" 
                               Foreground="#2C3E50" 
                               Margin="0,0,0,5"/>
                    <ComboBox x:Name="cboUnit" 
                              Height="35" 
                              Padding="5" 
                              FontSize="13" 
                              BorderBrush="#BDC3C7"
                              IsEditable="True">
                        <ComboBoxItem Content="pcs"/>
                        <ComboBoxItem Content="kg"/>
                        <ComboBoxItem Content="box"/>
                        <ComboBoxItem Content="pack"/>
                        <ComboBoxItem Content="bottle"/>
                        <ComboBoxItem Content="can"/>
                        <ComboBoxItem Content="bag"/>
                    </ComboBox>

                    <TextBlock Text="* Required fields" 
                               FontSize="11" 
                               Foreground="#7F8C8D" 
                               FontStyle="Italic" 
                               Margin="0,10,0,0"/>
                </StackPanel>

                <!-- Right Column: Description -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Description" 
                               FontSize="13" 
                               FontWeight="SemiBold" 
                               Foreground="#2C3E50" 
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="txtDescription" 
                             Padding="5" 
                             FontSize="13" 
                             TextWrapping="Wrap" 
                             AcceptsReturn="True" 
                             VerticalScrollBarVisibility="Auto"
                             BorderBrush="#BDC3C7"
                             Height="380"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,15,0,0">
            <Button x:Name="btnSave" 
                    Content="Save" 
                    Width="110" 
                    Height="40" 
                    Margin="0,0,10,0" 
                    Background="#27AE60" 
                    Foreground="White" 
                    BorderThickness="0" 
                    FontSize="14" 
                    FontWeight="SemiBold"
                    Cursor="Hand"
                    Click="btnSave_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#229954"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button x:Name="btnCancel" 
                    Content="Cancel" 
                    Width="110" 
                    Height="40" 
                    Background="#95A5A6" 
                    Foreground="White" 
                    BorderThickness="0" 
                    FontSize="14" 
                    FontWeight="SemiBold"
                    Cursor="Hand"
                    Click="btnCancel_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#7F8C8D"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>