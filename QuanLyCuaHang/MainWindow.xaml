<Window x:Class="QuanLyCuaHang.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Store Management System"
        Height="600"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2C3E50" Height="80">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="STORE MANAGEMENT SYSTEM" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="White"/>
                    <TextBlock x:Name="txtWelcome" 
                               Text="Welcome, Employee" 
                               FontSize="14" 
                               Foreground="#ECF0F1" 
                               Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center">
                    <TextBlock x:Name="txtDateTime" 
                               Text="" 
                               FontSize="14" 
                               Foreground="White" 
                               VerticalAlignment="Center" 
                               Margin="0,0,20,0"/>
                    <Button x:Name="btnLogout" 
                            Content="Logout" 
                            Width="100" 
                            Height="35" 
                            Background="#E74C3C" 
                            Foreground="White" 
                            BorderThickness="0" 
                            FontWeight="Bold" 
                            Cursor="Hand"
                            Click="btnLogout_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="5" 
                                                    Padding="10,5">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#C0392B"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar Menu -->
            <Border Grid.Column="0" 
                    Background="White" 
                    CornerRadius="10" 
                    Margin="0,0,10,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel Margin="0,20,0,0">
                    <TextBlock Text="MENU" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="#2C3E50" 
                               Margin="20,0,20,20"/>

                    <!-- Thêm button Dashboard vào menu sau TextBlock "MENU" -->
                    <Button x:Name="btnDashboard" 
        Content="Dashboard" 
        Height="50" 
        Margin="10,5" 
        Background="#F39C12" 
        Foreground="White" 
        BorderThickness="0" 
        FontSize="14" 
        FontWeight="SemiBold" 
        HorizontalContentAlignment="Center" 
        Cursor="Hand"
        Click="btnDashboard_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                            VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E67E22"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="btnPayment" 
                            Content="Payment" 
                            Height="50" 
                            Margin="10,5" 
                            Background="#3498DB" 
                            Foreground="White" 
                            BorderThickness="0" 
                            FontSize="14" 
                            FontWeight="SemiBold" 
                            HorizontalContentAlignment="Center" 
                            Cursor="Hand"
                            Click="btnPayment_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2E86C1"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="btnOrderManagement" 
                            Content="Order Management" 
                            Height="50" 
                            Margin="10,5" 
                            Background="#16A085" 
                            Foreground="White" 
                            BorderThickness="0" 
                            FontSize="14" 
                            FontWeight="SemiBold" 
                            HorizontalContentAlignment="Center" 
                            Cursor="Hand"
                            Click="btnOrderManagement_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#138D75"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="btnProductManagement" 
                            Content="Product Management" 
                            Height="50" 
                            Margin="10,5" 
                            Background="#9B59B6" 
                            Foreground="White" 
                            BorderThickness="0" 
                            FontSize="14" 
                            FontWeight="SemiBold" 
                            HorizontalContentAlignment="Center" 
                            Cursor="Hand"
                            Click="btnProductManagement_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#8E44AD"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Content Area -->
            <Border Grid.Column="1" 
                 Background="White" 
                CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
                </Border.Effect>

                <Grid>
                    <!-- Default Welcome Screen -->
                    <StackPanel x:Name="WelcomePanel" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center">
                        <TextBlock Text="Welcome to Store Management System" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#2C3E50" 
                       TextAlignment="Center"/>
                        <TextBlock Text="Please select a function from the menu" 
                       FontSize="16" 
                       Foreground="#7F8C8D" 
                       TextAlignment="Center" 
                       Margin="0,10,0,0"/>
                    </StackPanel>

                    <!-- Content Host -->
                    <ContentControl x:Name="MainContentControl" 
                        Visibility="Collapsed"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
