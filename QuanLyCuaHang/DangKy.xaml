<Window x:Class="QuanLyCuaHang.DangKy"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Register - Store Management System"
        Height="560"
        Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#EEF1F4">

	<Grid>
		<Border Width="350"
                Padding="28"
                Background="White"
                CornerRadius="14"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

			<!-- Shadow -->
			<Border.Effect>
				<DropShadowEffect BlurRadius="15"
                                  ShadowDepth="2"
                                  Opacity="0.2"/>
			</Border.Effect>

			<StackPanel>

				<!-- Title -->
				<TextBlock Text="REGISTER"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#2C3E50"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

				<!-- Full Name -->
				<TextBlock Text="Full Name"
                           Foreground="#7F8C8D"
                           FontSize="12"/>
				<TextBox Height="38"
                         Margin="0,6,0,14"
                         Padding="10"
                         BorderBrush="#DADADA"
                         BorderThickness="1"
                         Background="#FAFAFA"/>

				<!-- Email -->
				<TextBlock Text="Email"
                           Foreground="#7F8C8D"
                           FontSize="12"/>
				<TextBox Height="38"
                         Margin="0,6,0,14"
                         Padding="10"
                         BorderBrush="#DADADA"
                         BorderThickness="1"
                         Background="#FAFAFA"/>

				<!-- Password -->
				<TextBlock Text="Password"
                           Foreground="#7F8C8D"
                           FontSize="12"/>
				<PasswordBox Height="38"
                             Margin="0,6,0,14"
                             Padding="10"
                             BorderBrush="#DADADA"
                             BorderThickness="1"
                             Background="#FAFAFA"/>

				<!-- Confirm Password -->
				<TextBlock Text="Confirm Password"
                           Foreground="#7F8C8D"
                           FontSize="12"/>
				<PasswordBox Height="38"
                             Margin="0,6,0,22"
                             Padding="10"
                             BorderBrush="#DADADA"
                             BorderThickness="1"
                             Background="#FAFAFA"/>

				<!-- Register Button -->
				<Button Content="REGISTER"
                        Height="42"
                        Background="#27AE60"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="14"
                        BorderThickness="0"
                        Cursor="Hand"/>

				<!-- Login text -->
				<TextBlock HorizontalAlignment="Center"
                           Margin="0,18,0,0"
                           FontSize="12">
					<Run Text="Already have an account? "/>
					<Run Text="Login"
                         Foreground="#3498DB"
                         FontWeight="SemiBold"/>
				</TextBlock>

			</StackPanel>
		</Border>
	</Grid>
</Window>