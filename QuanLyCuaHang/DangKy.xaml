<Window x:Class="QuanLyCuaHang.DangKy"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng ký"
        Height="520"
        Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

	<Grid Background="#F4F6F8">
		<Border Width="340"
                Padding="25"
                CornerRadius="10"
                Background="White"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

			<StackPanel>

				<TextBlock Text="ĐĂNG KÝ"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#2C3E50"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>
    
				<TextBlock Text="Tên đăng nhập"/>
				<TextBox x:Name="txtUsername"
                         Height="32"
                         Margin="0,5,0,10"/>

				<TextBlock Text="Mật khẩu"/>
				<PasswordBox x:Name="txtPassword"
                             Height="32"
                             Margin="0,5,0,10"/>

				<TextBlock Text="Xác nhận mật khẩu"/>
				<PasswordBox x:Name="txtConfirmPassword"
                             Height="32"
                             Margin="0,5,0,10"/>

				<TextBlock Text="Vai trò"/>
				<ComboBox x:Name="cbRole"
                          Height="32"
                          Margin="0,5,0,20">
					<ComboBoxItem Content="Nhân viên"/>
					<ComboBoxItem Content="Quản lý"/>
				</ComboBox>

				<Button Content="ĐĂNG KÝ"
                        Height="40"
                        Background="#3498DB"
                        Foreground="White"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="BtnDangKy_Click"/>

				<TextBlock Text="Đã có tài khoản? Đăng nhập"
                           Foreground="#3498DB"
                           Margin="0,15,0,0"
                           Cursor="Hand"
                           HorizontalAlignment="Center"
                           MouseDown="TxtBackToLogin_MouseDown"/>
			</StackPanel>
		</Border>
	</Grid>
</Window>