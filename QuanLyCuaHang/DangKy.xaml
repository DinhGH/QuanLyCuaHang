<Window x:Class="QuanLyCuaHang.DangKy"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng ký tài khoản"
        Width="400"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">


    <Grid Background="#F5F6FA">
        <Border Background="White" 
                Padding="30" 
                CornerRadius="10"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Width="320">

            <StackPanel>

                <!-- TITLE TO NHẤT Ở TRÊN -->
                <TextBlock Text="ĐĂNG KÝ TÀI KHOẢN"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#2F3640"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <TextBlock Text="Tên đăng nhập" FontWeight="SemiBold"/>
                <TextBox x:Name="txtUsername"
                         Height="30"
                         Margin="0,5,0,15"
                         Padding="5"/>

                <TextBlock Text="Mật khẩu" FontWeight="SemiBold"/>
                <PasswordBox x:Name="txtPassword"
                             Height="30"
                             Margin="0,5,0,15"
                             Padding="5"/>

                <TextBlock Text="Xác nhận mật khẩu" FontWeight="SemiBold"/>
                <PasswordBox x:Name="txtConfirmPassword"
                             Height="30"
                             Margin="0,5,0,15"
                             Padding="5"/>

                <TextBlock Text="Vai trò" FontWeight="SemiBold"/>
                <ComboBox x:Name="cbRole"
                          Height="30"
                          Margin="0,5,0,20">
                    <ComboBoxItem Content="Admin"/>
                    <ComboBoxItem Content="Nhân viên"/>
                </ComboBox>

                <TextBlock x:Name="txtMessage"
                           Foreground="Red"
                           TextAlignment="Center"
                           Margin="0,0,0,10"
                           TextWrapping="Wrap"/>

                <Button Content="Đăng ký"
                        Height="35"
                        Background="#273C75"
                        Foreground="White"
                        FontWeight="Bold"
                        Margin="0,5,0,10"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnDangKy_Click"/>
                <Button Content="Quay lại đăng nhập"
                        Height="20"
                        Background="Transparent"
                        Foreground="#273C75"
                        BorderBrush="Transparent"
                        Cursor="Hand"
                        Click="BtnQuayLai_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
