<UserControl x:Class="QuanLyCuaHang.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" 
                       Text="DASHBOARD" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#2C3E50" 
                       Margin="0,0,0,20"/>

            <!-- Statistics Cards -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Revenue Card -->
                <Border Grid.Column="0" 
                        Background="#27AE60" 
                        CornerRadius="10" 
                        Padding="20" 
                        Margin="0,0,10,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="💰 Total Revenue" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="White" 
                                   Margin="0,0,0,10"/>
                        <TextBlock x:Name="txtTotalRevenue" 
                                   Text="$0.00" 
                                   FontSize="28" 
                                   FontWeight="Bold" 
                                   Foreground="White"/>
                        <TextBlock Text="All time" 
                                   FontSize="12" 
                                   Foreground="#ECF0F1" 
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Total Orders Card -->
                <Border Grid.Column="1" 
                        Background="#3498DB" 
                        CornerRadius="10" 
                        Padding="20" 
                        Margin="0,0,10,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="📦 Total Orders" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="White" 
                                   Margin="0,0,0,10"/>
                        <TextBlock x:Name="txtTotalOrders" 
                                   Text="0" 
                                   FontSize="28" 
                                   FontWeight="Bold" 
                                   Foreground="White"/>
                        <TextBlock Text="All time" 
                                   FontSize="12" 
                                   Foreground="#ECF0F1" 
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Total Products Card -->
                <Border Grid.Column="2" 
                        Background="#9B59B6" 
                        CornerRadius="10" 
                        Padding="20" 
                        Margin="0,0,10,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="📊 Total Products" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="White" 
                                   Margin="0,0,0,10"/>
                        <TextBlock x:Name="txtTotalProducts" 
                                   Text="0" 
                                   FontSize="28" 
                                   FontWeight="Bold" 
                                   Foreground="White"/>
                        <TextBlock Text="In inventory" 
                                   FontSize="12" 
                                   Foreground="#ECF0F1" 
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Low Stock Alert Card -->
                <Border Grid.Column="3" 
                        Background="#E74C3C" 
                        CornerRadius="10" 
                        Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="⚠️ Low Stock" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="White" 
                                   Margin="0,0,0,10"/>
                        <TextBlock x:Name="txtLowStock" 
                                   Text="0" 
                                   FontSize="28" 
                                   FontWeight="Bold" 
                                   Foreground="White"/>
                        <TextBlock Text="Products &lt; 10" 
                                   FontSize="12" 
                                   Foreground="#ECF0F1" 
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Charts Row -->
            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Recent Orders -->
                <Border Grid.Column="0" 
                        Background="White" 
                        CornerRadius="10" 
                        Padding="20" 
                        Margin="0,0,10,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="📋 Recent Orders" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="#2C3E50" 
                                   Margin="0,0,0,15"/>
                        <DataGrid x:Name="dgRecentOrders" 
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  GridLinesVisibility="None"
                                  HeadersVisibility="Column"
                                  RowHeight="35"
                                  FontSize="13"
                                  BorderThickness="0"
                                  Height="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                                <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*"/>
                                <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat=${0:N2}}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Low Stock Products -->
                <Border Grid.Column="1" 
                        Background="White" 
                        CornerRadius="10" 
                        Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="⚠️ Low Stock Products" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="#2C3E50" 
                                   Margin="0,0,0,15"/>
                        <DataGrid x:Name="dgLowStockProducts" 
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  GridLinesVisibility="None"
                                  HeadersVisibility="Column"
                                  RowHeight="35"
                                  FontSize="13"
                                  BorderThickness="0"
                                  Height="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Product" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Stock" Binding="{Binding Quantity}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Today's Summary -->
            <Border Grid.Row="3" 
                    Background="White" 
                    CornerRadius="10" 
                    Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="📅 Today's Summary" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="#2C3E50" 
                               Margin="0,0,0,15"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Revenue Today" 
                                       FontSize="14" 
                                       Foreground="#7F8C8D" 
                                       Margin="0,0,0,5"/>
                            <TextBlock x:Name="txtTodayRevenue" 
                                       Text="$0.00" 
                                       FontSize="24" 
                                       FontWeight="Bold" 
                                       Foreground="#27AE60"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Orders Today" 
                                       FontSize="14" 
                                       Foreground="#7F8C8D" 
                                       Margin="0,0,0,5"/>
                            <TextBlock x:Name="txtTodayOrders" 
                                       Text="0" 
                                       FontSize="24" 
                                       FontWeight="Bold" 
                                       Foreground="#3498DB"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Average Order Value" 
                                       FontSize="14" 
                                       Foreground="#7F8C8D" 
                                       Margin="0,0,0,5"/>
                            <TextBlock x:Name="txtAvgOrderValue" 
                                       Text="$0.00" 
                                       FontSize="24" 
                                       FontWeight="Bold" 
                                       Foreground="#9B59B6"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>