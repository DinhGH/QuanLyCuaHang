<Window x:Class="QuanLyCuaHang.Register"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyCuaHang"
        mc:Ignorable="d"
        Title="Register - Store Management System" 
        Height="550" 
        Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Grid>
        <Border Width="350" Padding="30" Background="White" CornerRadius="15" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.2"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                           Text="REGISTER" 
                           FontSize="30" 
                           FontWeight="Bold" 
                           Foreground="#2C3E50" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,25"/>

                <!-- Full Name -->
                <TextBlock Grid.Row="1" 
                           Text="Full Name" 
                           FontSize="14" 
                           Foreground="#34495E" 
                           Margin="0,0,0,5"/>

                <Border Grid.Row="2" 
                        CornerRadius="8" 
                        BorderBrush="#D0D3D4" 
                        BorderThickness="1" 
                        Margin="0,0,0,12">
                    <TextBox x:Name="txtFullName" 
                             Height="40" 
                             FontSize="14" 
                             Padding="10" 
                             BorderThickness="0" 
                             Background="Transparent"/>
                </Border>

                <!-- Email -->
                <TextBlock Grid.Row="3" 
                           Text="Email" 
                           FontSize="14" 
                           Foreground="#34495E" 
                           Margin="0,0,0,5"/>

                <Border Grid.Row="4" 
                        CornerRadius="8" 
                        BorderBrush="#D0D3D4" 
                        BorderThickness="1" 
                        Margin="0,0,0,12">
                    <TextBox x:Name="txtEmail" 
                             Height="40" 
                             FontSize="14" 
                             Padding="10" 
                             BorderThickness="0" 
                             Background="Transparent"/>
                </Border>

                <!-- Password -->
                <TextBlock Grid.Row="5" 
                           Text="Password" 
                           FontSize="14" 
                           Foreground="#34495E" 
                           Margin="0,0,0,5"/>

                <Border Grid.Row="6" 
                        CornerRadius="8" 
                        BorderBrush="#D0D3D4" 
                        BorderThickness="1" 
                        Margin="0,0,0,12">
                    <Grid>
                        <PasswordBox x:Name="txtPassword" 
                                     Height="40" 
                                     FontSize="14" 
                                     Padding="10,10,45,10" 
                                     BorderThickness="0" 
                                     Background="Transparent"
                                     KeyDown="txtPassword_KeyDown"/>
                        <TextBox x:Name="txtPasswordVisible" 
                                 Height="40" 
                                 FontSize="14" 
                                 Padding="10,10,45,10" 
                                 BorderThickness="0" 
                                 Background="Transparent"
                                 Visibility="Collapsed"
                                 KeyDown="txtPasswordVisible_KeyDown"/>
                        <Button x:Name="btnTogglePassword"
                                Width="35"
                                Height="40"
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="btnTogglePassword_Click"
                                ToolTip="Show/Hide Password">
                            <TextBlock x:Name="txtToggleIcon" 
                                       Text="??" 
                                       FontSize="18" 
                                       Foreground="#7F8C8D"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Re-Password -->
                <TextBlock Grid.Row="7" 
                           Text="Confirm Password" 
                           FontSize="14" 
                           Foreground="#34495E" 
                           Margin="0,0,0,5"/>

                <Border Grid.Row="8" 
                        CornerRadius="8" 
                        BorderBrush="#D0D3D4" 
                        BorderThickness="1">
                    <Grid>
                        <PasswordBox x:Name="txtRePassword" 
                                     Height="40" 
                                     FontSize="14" 
                                     Padding="10,10,45,10" 
                                     BorderThickness="0" 
                                     Background="Transparent"
                                     KeyDown="txtRePassword_KeyDown"/>
                        <TextBox x:Name="txtRePasswordVisible" 
                                 Height="40" 
                                 FontSize="14" 
                                 Padding="10,10,45,10" 
                                 BorderThickness="0" 
                                 Background="Transparent"
                                 Visibility="Collapsed"
                                 KeyDown="txtRePasswordVisible_KeyDown"/>
                        <Button x:Name="btnToggleRePassword"
                                Width="35"
                                Height="40"
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="btnToggleRePassword_Click"
                                ToolTip="Show/Hide Password">
                            <TextBlock x:Name="txtToggleReIcon" 
                                       Text="??" 
                                       FontSize="18" 
                                       Foreground="#7F8C8D"/>
                        </Button>
                    </Grid>
                </Border>

                <TextBlock x:Name="lblError" 
                           Grid.Row="9" 
                           Foreground="Red" 
                           FontSize="12" 
                           Margin="0,10,0,0" 
                           HorizontalAlignment="Center" 
                           Visibility="Collapsed"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>

                <StackPanel Grid.Row="9" Orientation="Vertical" Margin="0,15,0,0">
                    <Button x:Name="btnRegister" 
                            Content="REGISTER" 
                            Height="45" 
                            Margin="0,0,0,10" 
                            FontSize="16" 
                            FontWeight="Bold" 
                            Background="#27AE60" 
                            Foreground="White" 
                            BorderThickness="0" 
                            Cursor="Hand"
                            Click="btnRegister_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#229954"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="btnBackToLogin" 
                            Content="Already have an account? Login" 
                            Background="Transparent" 
                            Foreground="#3498DB" 
                            BorderThickness="0" 
                            FontSize="13" 
                            Cursor="Hand" 
                            HorizontalAlignment="Center"
                            Click="btnBackToLogin_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>