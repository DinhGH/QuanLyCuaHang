<Window x:Class="QuanLyCuaHang.ThanhToan"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Payment - Point of Sale"
        Height="600"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                Padding="15"
                Margin="0,0,12,0"
                Background="#FFFFFF"
                CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="SHOPPING CART"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#374151"
                           Margin="0,0,0,12"/>

                <Button x:Name="btnThemSanPham"
                        Grid.Row="1"
                        Content="+ Add Product"
                        Width="160"
                        Height="36"
                        Margin="0,0,0,12"
                        Background="#6B7280"
                        Foreground="White"
                        BorderThickness="0"
                        Click="btnThemSanPham_Click"/>

                <ListView x:Name="lvSanPham"
                          Grid.Row="2"
                          Margin="0,0,0,12"
                          BorderBrush="#E5E7EB"
                          BorderThickness="1"
                          Background="White">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="10" Width="550">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding TenSP}" FontWeight="SemiBold"/>
                                        <TextBlock Foreground="#6B7280">
                                            <Run Text="Price: $"/>
                                            <Run Text="{Binding DonGia, Mode=OneWay, StringFormat={}{0:N2}}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center">
                                        <Run Text="Subtotal: $"/>
                                        <Run FontWeight="Bold" Text="{Binding ThanhTien, Mode=OneWay, StringFormat={}{0:N2}}"/>
                                    </TextBlock>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <Button Content="-" Width="30" Height="30" Background="#9CA3AF" Foreground="White" 
                                                Click="btnGiamSoLuong_Click" Tag="{Binding}"/>
                                        <TextBlock Text="{Binding SoLuong, Mode=OneWay}" Width="36" TextAlignment="Center" VerticalAlignment="Center"/>
                                        <Button Content="+" Width="30" Height="30" Background="#6B7280" Foreground="White"
                                                Click="btnTangSoLuong_Click" Tag="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Border Grid.Row="3"
                        Background="#6B7280"
                        Padding="14"
                        CornerRadius="4">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="TOTAL: $" FontSize="17" FontWeight="Bold" Foreground="White" Margin="0,0,10,0"/>
                        <TextBlock x:Name="txtTongTien" Text="0.00" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                Padding="18"
                Background="#FFFFFF"
                CornerRadius="6">
            <StackPanel>
                <TextBlock Text="PAYMENT INFORMATION"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#374151"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Full Name:"/>
                <TextBox x:Name="txtHoTen" Height="32" Margin="0,6,0,14"/>

                <TextBlock Text="Phone Number:"/>
                <TextBox x:Name="txtSDT" Height="32" Margin="0,6,0,14"/>

                <TextBlock Text="Address:"/>
                <TextBox x:Name="txtDiaChi" Height="32" Margin="0,6,0,18"/>

                <TextBlock Text="Payment Method:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <RadioButton x:Name="rdTienMat" Content="Cash" IsChecked="True" Checked="rdThanhToan_Checked"/>
                <RadioButton x:Name="rdChuyenKhoan" Content="Credit Card" Margin="0,6,0,18" Checked="rdThanhToan_Checked"/>

                <Separator Margin="0,0,0,18"/>

                <TextBlock Text="Cash Received:"/>
                <TextBox x:Name="txtTienKhachDua" Height="32" Margin="0,6,0,16" TextChanged="txtTienKhachDua_TextChanged"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                    <TextBlock Text="Change: $" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtTienThua" Text="0.00" FontWeight="Bold" Margin="10,0,0,0"/>
                </StackPanel>

                <Button x:Name="btnXuatHoaDon"
                        Content="CHECKOUT"
                        Height="48"
                        FontSize="16"
                        FontWeight="Bold"
                        Background="#374151"
                        Foreground="White"
                        BorderThickness="0"
                        Click="btnXuatHoaDon_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>